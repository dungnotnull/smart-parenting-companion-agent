# smart-parenting-companion — Environment Configuration

# --- LLM Provider ---
# Options: "claude" | "openai" | "ollama"
LLM_PROVIDER=claude
LLM_CLAUDE_API_KEY=sk-ant-...
LLM_CLAUDE_MODEL=claude-sonnet-4-6
LLM_OPENAI_API_KEY=sk-...
LLM_OPENAI_MODEL=gpt-4o
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# --- Database ---
SQLITE_PATH=data/family_profiles.db
ENCRYPTION_KEY=change-me-to-a-real-256-bit-key

# --- ChromaDB ---
CHROMA_PERSIST_DIR=data/chroma_store

# --- Scheduling ---
CRAWL_SCHEDULE_DAY=sun
CRAWL_SCHEDULE_HOUR=3
CRAWL_SCHEDULE_MINUTE=0

# --- Logging ---
LOG_LEVEL=INFO
